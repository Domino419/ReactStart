{
    "env" : {
        "es6" : true , 
        "node" : true
     }, 
     "extends": ["eslint:recommended", "prettier"] , 
     "globals": {
        "Atomics" : "readonly", 
        "SharedArrayBuffer" : "readonly"
      } , 
      "parserOptions": {
         "ecmaVersion": "latest",
        "sourceType": "module"
      }, 
      "rules": {
        "no-unused-vars":"warn",
        "no-console":"off",
        "no-undef": "error" // 정의되지 않은 변수 사용 시 에러
      } 
}